# Required: Your Gemini API key from https://aistudio.google.com/
GOOGLE_API_KEY=your_gemini_api_key_here

# Optional: Override the default LLM model (default: gemini-2.5-flash)
# LLM_MODEL=gemini-2.5-flash

# Optional: HuggingFace token — silences unauthenticated warnings and unlocks faster downloads.
# Get one at https://huggingface.co/settings/tokens (free, no credit card needed)
# HF_TOKEN=
